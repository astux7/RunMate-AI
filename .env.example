# Google Gemini API key (required)
GOOGLE_API_KEY=your_gemini_api_key_here

# Model to use for all agents (default: gemini-2.0-flash)
MODEL_NAME=gemini-2.0-flash

# Enable Google Search grounding for race lookups (recommended: true)
ENABLE_SEARCH_GROUNDING=true

# Save reports to output/ directory (optional: true/false)
SAVE_REPORTS=false
